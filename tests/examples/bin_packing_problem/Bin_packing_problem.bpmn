<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bpmnos="https://bpmnos.telematique.eu" id="sample-diagram" targetNamespace="http://bpmn.io/schema/bpmn" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd"><bpmn2:collaboration id="Bin_packing_problem"><bpmn2:documentation>Given a set of items, each having a specifed size, and a set of bins each having a specified capacity, the *Bin packing problem* can be described as the problem of finding the minimal number of bins required to include all items such that the total size of all items associated to a bin does not exceed the capacity of the bin. 

In the stochastic case, where actual item size is only revaled when handling the item, the capacity may be exceeded if the actual size is higher than the expected size. In this case, the bin is cleared to make space for the new item. Cleared bins count as a new bin being used.</bpmn2:documentation><bpmn2:extensionElements><bpmnos:attributes><bpmnos:attribute id="Items" type="integer" name="items" /><bpmnos:attribute id="Bins" type="integer" name="bins" /><bpmnos:attribute id="ItemsAllocated" type="integer" name="items_allocated := 0" /><bpmnos:attribute id="ItemsRequested" type="integer" name="items_requested := 0" /></bpmnos:attributes></bpmn2:extensionElements><bpmn2:participant id="Participant_1c07lhk" name="Item process" processRef="ItemProcess" /><bpmn2:participant id="Participant_0gkimz7" name="Bin process" processRef="BinProcess" /></bpmn2:collaboration><bpmn2:process id="ItemProcess" isExecutable="true"><bpmn2:extensionElements><bpmnos:status><bpmnos:attributes><bpmnos:attribute id="Timestamp" type="decimal" name="timestamp" /><bpmnos:attribute id="Size" type="decimal" name="size" /></bpmnos:attributes></bpmnos:status></bpmn2:extensionElements><bpmn2:dataObject id="DataObject_1xt50y3"><bpmn2:extensionElements><bpmnos:attributes><bpmnos:attribute id="Instance" type="string" name="instance" /></bpmnos:attributes></bpmn2:extensionElements></bpmn2:dataObject><bpmn2:startEvent id="StartEventItem"><bpmn2:outgoing>Flow_1qgy5y7</bpmn2:outgoing></bpmn2:startEvent><bpmn2:endEvent id="EndEventItem"><bpmn2:incoming>Flow_1aezece</bpmn2:incoming></bpmn2:endEvent><bpmn2:sendTask id="RequestActivity" name="Request"><bpmn2:extensionElements><bpmnos:messages><bpmnos:message name="Request"><bpmnos:content key="Item" attribute="instance" /><bpmnos:content key="Size" attribute="size" /></bpmnos:message></bpmnos:messages><bpmnos:status><bpmnos:operators><bpmnos:operator id="Operator_158geoe" expression="items_requested += 1" /></bpmnos:operators></bpmnos:status></bpmn2:extensionElements><bpmn2:incoming>Flow_1qgy5y7</bpmn2:incoming><bpmn2:outgoing>Flow_1aezece</bpmn2:outgoing></bpmn2:sendTask><bpmn2:sequenceFlow id="Flow_1qgy5y7" sourceRef="StartEventItem" targetRef="RequestActivity" /><bpmn2:sequenceFlow id="Flow_1aezece" sourceRef="RequestActivity" targetRef="EndEventItem" /></bpmn2:process><bpmn2:process id="BinProcess" isExecutable="true"><bpmn2:extensionElements><bpmnos:status><bpmnos:attributes><bpmnos:attribute id="Timestamp" type="decimal" name="timestamp" /></bpmnos:attributes><bpmnos:restrictions><bpmnos:restriction id="Restriction_3br81vk" expression="total_size &#60;= capacity" /></bpmnos:restrictions></bpmnos:status></bpmn2:extensionElements><bpmn2:dataObject id="DataObject_2xt50y3"><bpmn2:extensionElements><bpmnos:attributes><bpmnos:attribute id="Instance" type="string" name="instance" /></bpmnos:attributes></bpmn2:extensionElements></bpmn2:dataObject><bpmn2:sequenceFlow id="Flow_1rghjse" sourceRef="StartEvent" targetRef="ConditionalEvent" /><bpmn2:startEvent id="StartEvent"><bpmn2:outgoing>Flow_1rghjse</bpmn2:outgoing></bpmn2:startEvent><bpmn2:subProcess id="EventSubProcess" triggeredByEvent="true"><bpmn2:extensionElements><bpmnos:status><bpmnos:attributes><bpmnos:attribute id="Item" type="string" name="item" /><bpmnos:attribute id="Size" type="decimal" name="size" /></bpmnos:attributes><bpmnos:operators><bpmnos:operator id="Operator_2bo3f0c" expression="usage_count := max{usage_count,1}" /><bpmnos:operator id="Operator_3cjc7m2" expression="items_allocated += 1" /></bpmnos:operators></bpmnos:status></bpmn2:extensionElements><bpmn2:sequenceFlow id="Flow_04nmpfp" sourceRef="CatchRequestMessage" targetRef="AdHocSubProcess" /><bpmn2:endEvent id="EndEventSubProcess" name="Item included"><bpmn2:incoming>Flow_16v4xsj</bpmn2:incoming></bpmn2:endEvent><bpmn2:startEvent id="CatchRequestMessage" name="Request" isInterrupting="false"><bpmn2:extensionElements><bpmnos:message name="Request"><bpmnos:content key="Item" attribute="item" /><bpmnos:content key="Size" attribute="size" /></bpmnos:message><bpmnos:guidance type="message"><bpmnos:attributes><bpmnos:attribute id="Attribute_2jeu4u0" type="decimal" name="residual" objective="minimize" weight="1" /></bpmnos:attributes><bpmnos:restrictions><bpmnos:restriction id="Restriction_0ifq5es" expression="total_size + size &#60;= capacity" /><bpmnos:restriction id="Restriction_2ugp22b" expression="items_requested == items" /></bpmnos:restrictions><bpmnos:operators><bpmnos:operator id="Operator_2910hvr" expression="residual := (capacity - total_size - size)/capacity" type="decimal" /></bpmnos:operators></bpmnos:guidance></bpmn2:extensionElements><bpmn2:outgoing>Flow_04nmpfp</bpmn2:outgoing><bpmn2:messageEventDefinition id="MessageEventDefinition_1xfumwd" /></bpmn2:startEvent><bpmn2:adHocSubProcess id="AdHocSubProcess" ordering="Sequential"><bpmn2:extensionElements><bpmnos:status /></bpmn2:extensionElements><bpmn2:incoming>Flow_04nmpfp</bpmn2:incoming><bpmn2:outgoing>Flow_16v4xsj</bpmn2:outgoing><bpmn2:performer name="Sequential" /><bpmn2:subProcess id="HandleItemActivity" name="Handle item"><bpmn2:startEvent id="HandleItemStartEvent"><bpmn2:outgoing>Flow_0z2gs8w</bpmn2:outgoing></bpmn2:startEvent><bpmn2:exclusiveGateway id="SplitGateway"><bpmn2:incoming>Flow_08ooq6g</bpmn2:incoming><bpmn2:outgoing>Flow_0an2vmk</bpmn2:outgoing><bpmn2:outgoing>Flow_0kc2iyd</bpmn2:outgoing></bpmn2:exclusiveGateway><bpmn2:sequenceFlow id="Flow_0z2gs8w" sourceRef="HandleItemStartEvent" targetRef="InspectItem" /><bpmn2:task id="ClearBin" name="Clear bin"><bpmn2:extensionElements><bpmnos:status><bpmnos:operators><bpmnos:operator id="Operator_19vutrs" expression="usage_count += 1" /><bpmnos:operator id="Operator_1oho8rq" expression="total_size := 0" /></bpmnos:operators></bpmnos:status></bpmn2:extensionElements><bpmn2:incoming>Flow_0kc2iyd</bpmn2:incoming><bpmn2:outgoing>Flow_0xxf4in</bpmn2:outgoing></bpmn2:task><bpmn2:exclusiveGateway id="MergeGateway"><bpmn2:incoming>Flow_0xxf4in</bpmn2:incoming><bpmn2:incoming>Flow_0an2vmk</bpmn2:incoming><bpmn2:outgoing>Flow_0bmt6n9</bpmn2:outgoing></bpmn2:exclusiveGateway><bpmn2:sequenceFlow id="Flow_0xxf4in" sourceRef="ClearBin" targetRef="MergeGateway" /><bpmn2:sequenceFlow id="Flow_0an2vmk" name="sufficient capacity" sourceRef="SplitGateway" targetRef="MergeGateway"><bpmn2:extensionElements><bpmnos:restrictions><bpmnos:restriction id="Condition_088rne3" expression="total_size + size &#60;= capacity" parameter="[object Object]" /></bpmnos:restrictions></bpmn2:extensionElements></bpmn2:sequenceFlow><bpmn2:sequenceFlow id="Flow_0kc2iyd" name="insufficient capacity" sourceRef="SplitGateway" targetRef="ClearBin"><bpmn2:extensionElements><bpmnos:restrictions><bpmnos:restriction id="Condition_0v9pckr" expression="total_size + size &#62; capacity" parameter="[object Object]" /></bpmnos:restrictions></bpmn2:extensionElements></bpmn2:sequenceFlow><bpmn2:sequenceFlow id="Flow_0bmt6n9" sourceRef="MergeGateway" targetRef="IncludeItem" /><bpmn2:endEvent id="HandleItemEndEvent"><bpmn2:incoming>Flow_0buv180</bpmn2:incoming></bpmn2:endEvent><bpmn2:task id="InspectItem" name="Inspect item"><bpmn2:incoming>Flow_0z2gs8w</bpmn2:incoming><bpmn2:outgoing>Flow_08ooq6g</bpmn2:outgoing></bpmn2:task><bpmn2:sequenceFlow id="Flow_08ooq6g" sourceRef="InspectItem" targetRef="SplitGateway" /><bpmn2:task id="IncludeItem" name="Include item"><bpmn2:extensionElements><bpmnos:status><bpmnos:operators><bpmnos:operator id="Operator_1gtdkd6" expression="total_size += size" /></bpmnos:operators></bpmnos:status></bpmn2:extensionElements><bpmn2:incoming>Flow_0bmt6n9</bpmn2:incoming><bpmn2:outgoing>Flow_0buv180</bpmn2:outgoing></bpmn2:task><bpmn2:sequenceFlow id="Flow_0buv180" sourceRef="IncludeItem" targetRef="HandleItemEndEvent" /></bpmn2:subProcess></bpmn2:adHocSubProcess><bpmn2:sequenceFlow id="Flow_16v4xsj" sourceRef="AdHocSubProcess" targetRef="EndEventSubProcess" /></bpmn2:subProcess><bpmn2:dataObjectReference id="DataObjectReference_04cxu4w" dataObjectRef="DataObject_1pee096" /><bpmn2:dataObject id="DataObject_1pee096"><bpmn2:extensionElements><bpmnos:attributes><bpmnos:attribute id="Capacity" type="decimal" name="capacity" /><bpmnos:attribute id="TotalSize" type="decimal" name="total_size := 0" /><bpmnos:attribute id="Used" type="integer" name="usage_count := 0" objective="minimize" weight="1" /></bpmnos:attributes></bpmn2:extensionElements></bpmn2:dataObject><bpmn2:sequenceFlow id="Flow_1h1zaah" sourceRef="ConditionalEvent" targetRef="EndEventBin" /><bpmn2:intermediateCatchEvent id="ConditionalEvent" name="All items allocated"><bpmn2:extensionElements><bpmnos:restrictions><bpmnos:restriction id="Condition_05dlon8" expression="items_allocated == items" parameter="[object Object]" /></bpmnos:restrictions></bpmn2:extensionElements><bpmn2:incoming>Flow_1rghjse</bpmn2:incoming><bpmn2:outgoing>Flow_1h1zaah</bpmn2:outgoing><bpmn2:conditionalEventDefinition id="ConditionalEventDefinition_1jqqvkt"><bpmn2:condition xsi:type="bpmn2:tFormalExpression" /></bpmn2:conditionalEventDefinition></bpmn2:intermediateCatchEvent><bpmn2:endEvent id="EndEventBin"><bpmn2:incoming>Flow_1h1zaah</bpmn2:incoming></bpmn2:endEvent><bpmn2:performer name="Sequential" /></bpmn2:process><bpmndi:BPMNDiagram id="BPMNDiagram_1"><bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Bin_packing_problem"><bpmndi:BPMNShape id="Participant_1c07lhk_di" bpmnElement="Participant_1c07lhk" isHorizontal="true"><dc:Bounds x="350" y="133" width="1180" height="250" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="StartEventItem"><dc:Bounds x="422" y="240" width="36" height="36" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Event_133ovn6_di" bpmnElement="EndEventItem"><dc:Bounds x="662" y="240" width="36" height="36" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_1s4av1k_di" bpmnElement="RequestActivity"><dc:Bounds x="510" y="218" width="100" height="80" /></bpmndi:BPMNShape><bpmndi:BPMNEdge id="Flow_1q